# Client-safe values from Supabase Dashboard > Project Settings > API
# The publishable key is intentionally usable in browser apps. Never use a secret key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
# Public browser push identity. The private half belongs only in Supabase Edge Function secrets.
VITE_VAPID_PUBLIC_KEY=replace_with_public_vapid_key
